{
  "siteName": "ZooTracker Uptime",
  "baseUrl": "/zootracker-uptime",
  "historyLimit": 18000,
  "slowThresholdMs": 1000,
  "checks": [
    {
      "name": "Frontend HTML",
      "phase": "frontend",
      "description": "SPA entry document served directly by nginx.",
      "url": "https://zootracker.app/",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "text/html",
        "bodyIncludes": ["<div id=\"root\""]
      }
    },
    {
      "name": "API Root",
      "phase": "api-shallow",
      "description": "Shallow FastAPI process check without touching the database.",
      "url": "https://zootracker.app/api/",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "application/json",
        "bodyIncludes": ["Zoo Tracker API"]
      }
    },
    {
      "name": "Site Config",
      "phase": "api-shallow",
      "description": "Public auth-provider config returned by the backend.",
      "url": "https://zootracker.app/api/site/config",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "application/json",
        "jsonPaths": [
          "authProviders.google.enabled",
          "authProviders.apple.enabled"
        ]
      }
    },
    {
      "name": "Location Estimate",
      "phase": "api-shallow",
      "description": "Cheap dynamic endpoint that should respond even without DB pressure.",
      "url": "https://zootracker.app/api/location/estimate",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "application/json",
        "jsonPaths": ["latitude", "longitude"]
      }
    },
    {
      "name": "Site Summary",
      "phase": "api-db",
      "description": "Aggregate counts from the primary database.",
      "url": "https://zootracker.app/api/site/summary",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "application/json",
        "jsonPaths": ["species", "zoos", "countries", "sightings"],
        "jsonMin": {
          "species": 1,
          "zoos": 1,
          "countries": 1,
          "sightings": 1
        }
      }
    },
    {
      "name": "Zoos Search",
      "phase": "api-db",
      "description": "List endpoint backed by PostgreSQL search and pagination.",
      "url": "https://zootracker.app/api/zoos?limit=1",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "application/json",
        "jsonPaths": ["items.0.slug", "items.0.name", "total"],
        "jsonMin": {
          "total": 1
        }
      }
    },
    {
      "name": "Animals Search",
      "phase": "api-db",
      "description": "List endpoint backed by PostgreSQL search and image metadata.",
      "url": "https://zootracker.app/api/animals?limit=1",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "application/json",
        "jsonPaths": ["items.0.slug", "items.0.default_image_url", "total"],
        "jsonMin": {
          "total": 1
        }
      }
    },
    {
      "name": "Sitemap",
      "phase": "seo",
      "description": "Crawler-facing XML generated by the backend.",
      "url": "https://zootracker.app/sitemap.xml",
      "method": "GET",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "application/xml",
        "bodyIncludes": ["<?xml"],
        "headerExists": ["etag"]
      }
    },
    {
      "name": "Animal Image",
      "phase": "storage",
      "description": "Object storage image delivered through nginx proxy cache.",
      "url": "https://zootracker.app/assets/animals/indian-peafowl/M45509204_320w.jpg",
      "method": "HEAD",
      "timeoutMs": 10000,
      "expect": {
        "status": [200],
        "contentTypeIncludes": "image/"
      }
    }
  ],
  "timespans": ["24h", "7d", "30d", "all"]
}
